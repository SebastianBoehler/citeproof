{
  "datasets": [
    {
      "name": "primary",
      "path": "claim_support.jsonl",
      "split": "curated"
    },
    {
      "name": "edge",
      "path": "edge_cases/claim_support.jsonl",
      "split": "adversarial"
    },
    {
      "name": "real_paper",
      "path": "real_paper/claim_support.jsonl",
      "split": "heldout_real_paper"
    },
    {
      "name": "real_paper_adversarial",
      "path": "real_paper/adversarial_claim_support.jsonl",
      "split": "generated_adversarial"
    }
  ],
  "gates": {
    "max_false_supported_rate": 0.0,
    "min_accuracy": 1.0,
    "max_manual_review_rate": 0.35,
    "min_supported_precision": 1.0,
    "min_contradiction_recall": 1.0,
    "min_unsupported_recall": 1.0
  }
}
